{
	admin :2019
	servers {
		metrics
	}
}

:80 {
	root * /srv
	encode gzip

	# Observability reverse proxies
	handle_path /grafana* {
		reverse_proxy grafana:3000
	}
	handle_path /prometheus* {
		reverse_proxy prometheus:9090
	}

	# Cache static assets
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# SPA fallback
	try_files {path} {path}/ /index.html
	file_server
}
